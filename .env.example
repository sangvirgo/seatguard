# ============================================================
# SeatGuard — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_DB=seatguard
POSTGRES_USER=seatguard
POSTGRES_PASSWORD=CHANGE_ME

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_RANDOM_STRING
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# ─── Google OAuth2 ────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2/callback/google

# ─── Admin Emails (comma-separated) ──────────────────────
ADMIN_EMAILS=admin@example.com

# ─── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME
CLOUDINARY_SECURE=true

# ─── Frontend / Gateway URLs ─────────────────────────────
FRONTEND_URL=http://localhost:3001
API_GATEWAY_URL=http://api-gateway:8080

# ─── Booking Service ─────────────────────────────────────
BOOKING_HOLD_TTL=300
BOOKING_DEFAULT_AMOUNT=50.00
BOOKING_EXPIRY_CHECK_MS=30000

# ─── MoMo Payment (sandbox) ─────────────────────────────
MOMO_ENABLED=false
MOMO_PARTNER_CODE=CHANGE_ME
MOMO_ACCESS_KEY=CHANGE_ME
MOMO_SECRET_KEY=CHANGE_ME
MOMO_ENDPOINT=https://test-payment.momo.vn
MOMO_RETURN_URL=http://localhost:3001/payment/result
MOMO_NOTIFY_URL=http://localhost:8080/api/payments/momo/ipn

# ─── VNPay Payment (sandbox) ─────────────────────────────
VNPAY_ENABLED=false
VNPAY_TMN_CODE=CHANGE_ME
VNPAY_HASH_SECRET=CHANGE_ME
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3001/payment/result
VNPAY_IPN_URL=http://localhost:8080/api/payments/vnpay/ipn
